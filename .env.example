# Template de variáveis de ambiente do Bancada.
# Copie este arquivo para .env.local e preencha os valores reais lá —
# .env.local nunca é commitado (veja .gitignore). Este arquivo (.env.example)
# deve conter só placeholders vazios, nunca um valor real.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# URL do projeto Supabase. Painel do projeto → Project Settings → API →
# "Project URL".
VITE_SUPABASE_URL=

# Chave anônima (pública) do projeto Supabase — protegida por RLS, é segura
# pra expor no client. Painel do projeto → Project Settings → API →
# "Project API keys" → "anon public".
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Stripe (cobrança da assinatura do Bancada — ainda não conectado)
# ---------------------------------------------------------------------------
# Chave publicável do Stripe, usada no client (Checkout/Elements). Dashboard
# da Stripe → Developers → API keys → "Publishable key".
VITE_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Evolution API (integração futura de WhatsApp — não implementada ainda)
# ---------------------------------------------------------------------------
# Reservado para quando a notificação de cliente via WhatsApp for construída.
# Sem prefixo VITE_ de propósito: nunca deve ser acessível pelo client.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
