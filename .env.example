# Template de variáveis de ambiente do Bancada.
# Copie este arquivo para .env.local e preencha os valores reais lá —
# .env.local nunca é commitado (veja .gitignore). Este arquivo (.env.example)
# deve conter só placeholders vazios, nunca um valor real.

# ---------------------------------------------------------------------------
# Supabase (client-side — prefixo NEXT_PUBLIC_, exposto no bundle do navegador)
# ---------------------------------------------------------------------------
# URL do projeto Supabase. Painel do projeto → Project Settings → API →
# "Project URL".
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (pública) do projeto Supabase — protegida por RLS, é segura
# pra expor no client. Painel do projeto → Project Settings → API →
# "Project API keys" → "anon public".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Supabase — SERVER-SIDE apenas (sem prefixo NEXT_PUBLIC_, nunca vai pro
# client). Usada por src/app/api/team/invite/route.ts pra criar o usuário
# convidado via auth.admin — ignora RLS por completo, então a rota verifica
# manualmente que quem chama é dono da empresa antes de usar essa chave.
# ---------------------------------------------------------------------------
# Painel do Supabase → seu projeto → Project Settings → API → "Project API
# keys" → "service_role" (secreta — NUNCA prefixar com NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe — client-side (cobrança da assinatura do Bancada — ainda não conectado)
# ---------------------------------------------------------------------------
# Chave publicável do Stripe, usada no client (Checkout/Elements). Dashboard
# da Stripe → Developers → API keys → "Publishable key".
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Stripe — SERVER-SIDE apenas (sem prefixo NEXT_PUBLIC_, nunca vai pro client).
# Usadas por src/app/api/stripe/webhook/route.ts. Billing ainda não está
# conectado — só preencha quando for testar a integração de verdade.
# ---------------------------------------------------------------------------
# Dashboard da Stripe → Developers → API keys → "Secret key" (começa com
# sk_test_ ou sk_live_). NUNCA prefixar com NEXT_PUBLIC_.
STRIPE_SECRET_KEY=

# Dashboard da Stripe → Developers → Webhooks → (seu endpoint, depois de
# criado) → "Signing secret" (começa com whsec_). Só existe depois que você
# cadastrar o endpoint /api/stripe/webhook no Dashboard — enquanto isso não
# acontece, deixe vazio.
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Evolution API (integração futura de WhatsApp — não implementada ainda)
# ---------------------------------------------------------------------------
# Reservado para quando a notificação de cliente via WhatsApp for construída.
# Sem prefixo NEXT_PUBLIC_ de propósito: nunca deve ser acessível pelo client.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ---------------------------------------------------------------------------
# Criptografia do PIN/padrão de bloqueio do aparelho — SERVER-SIDE apenas
# (sem prefixo NEXT_PUBLIC_, nunca vai pro client). Usada por
# src/lib/server/device-secret.ts, chamada só a partir de
# src/app/api/device-secret/route.ts e .../reveal/route.ts. Sem essa chave,
# a criação de OS/Orçamento continua funcionando normalmente — só o campo de
# bloqueio deixa de ser salvo (fica só em tela, como já era antes).
# ---------------------------------------------------------------------------
# Precisa ser uma chave AES-256 de 32 bytes, codificada em base64. Gere uma
# com:
#   openssl rand -base64 32
# Nunca reaproveite a mesma chave entre ambientes (dev/preview/produção) —
# gere uma nova pra cada uma. Se essa chave for perdida ou trocada, todo PIN
# já salvo se torna irrecuperável (não há como decifrar sem ela).
DEVICE_SECRET_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Vercel Cron — SERVER-SIDE apenas. Autentica as chamadas que só o Vercel Cron
# deve poder fazer (hoje: src/app/api/cron/purge-device-secrets/route.ts,
# agendado em vercel.json). Sem confirmação de que pg_cron está disponível no
# projeto Supabase conectado, a purga de device_unlock_secret_encrypted
# roda por aqui em vez de um job dentro do Postgres.
# ---------------------------------------------------------------------------
# Gere com `openssl rand -base64 32`. Configure o MESMO valor na env var
# CRON_SECRET do projeto na Vercel — é assim que a Vercel sabe adicionar o
# header "Authorization: Bearer <valor>" nas chamadas que ela mesma dispara
# pro cron; sem isso configurado dos dois lados, a rota responde 401 sempre
# (inclusive pra Vercel Cron de verdade) ou fica sem nenhuma verificação.
CRON_SECRET=
